# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Used by examples/create_workflow.py and examples/search.py

# Required — API key from Apruvly dashboard (Settings → API Keys)
APRUVLY_API_KEY=wf-your-api-key-here

# Optional — API origin (default: https://api.apruvly.io)
# Examples: http://localhost:1509  |  https://api.apruvly.io
APRUVLY_BASE_URL=https://api.apruvly.io

# Optional — client throttle / retry (conservative defaults shown)
# APRUVLY_MIN_INTERVAL=0.2
# APRUVLY_MAX_RETRIES=2
# APRUVLY_BACKOFF_FACTOR=1.0
# APRUVLY_BACKOFF_MAX=30
# APRUVLY_RETRY_JITTER=true

# Optional — approver email for create_workflow.py
APRUVLY_APPROVER_EMAIL=you@example.com

# Optional — webhook URL fired on workflow_completed (create_workflow.py)
APRUVLY_WEBHOOK_URL=https://example.com/apruvly-hook

# Optional — full-text search query (search.py)
APRUVLY_SEARCH_QUERY=
